# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MetaTrader 5 Credentials (Primary)
MT5_LOGIN="YOUR_MT5_LOGIN"
MT5_PASSWORD="YOUR_MT5_PASSWORD"
MT5_SERVER="YOUR_MT5_SERVER"

# Exness Kenya
EXNESS_LOGIN="YOUR_EXNESS_LOGIN"
EXNESS_PASSWORD="YOUR_EXNESS_PASSWORD"
EXNESS_SERVER="YOUR_EXNESS_SERVER"

# Valetax
VALETAX_LOGIN="YOUR_VALETAX_LOGIN"
VALETAX_PASSWORD="YOUR_VALETAX_PASSWORD"
VALETAX_SERVER="YOUR_VALETAX_SERVER"

# Pepperstone Kenya
PEPPERSTONE_LOGIN="YOUR_PEPPERSTONE_LOGIN"
