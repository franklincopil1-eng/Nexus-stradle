rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Helper for Trading State validation
    function isValidTradingState(data) {
      return data.price is number 
        && data.spread is number
        && data.systemStatus in ['ENGAGED', 'HALTED']
        && data.lastHeartbeat is number;
    }

    // Helper for Log validation
    function isValidLog(data) {
      return data.timestamp is string 
        && data.level in ['INFO', 'STRATEGY', 'EXECUTION', 'ERROR', 'SUCCESS']
        && data.message is string
        && data.message.size() < 1000;
    }

    // Global System Components
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        (docId == 'state' && isValidTradingState(incoming())) ||
        (docId == 'backtest')
      );
    }

    // Logs - Append Only
    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidLog(incoming());
      allow update, delete: if false;
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Commands
    match /commands/{commandId} {
      allow read, write: if isSignedIn();
    }
  }
}
